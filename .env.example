# FatSecret Platform API — OAuth 2.0 client_credentials
# Get these from https://platform.fatsecret.com/  (My Account → API Credentials)
# Set the REAL values as Environment Variables in Vercel (Project → Settings →
# Environment Variables). NEVER commit real values to the repo.
FATSECRET_CLIENT_ID=your_client_id_here
FATSECRET_CLIENT_SECRET=your_client_secret_here

# Optional: comma-separated list of allowed browser origins for the proxy.
# Leave unset to reflect the request origin (fine when the frontend and the
# /api functions are served from the same Vercel domain).
# ALLOWED_ORIGIN=https://your-app.vercel.app
